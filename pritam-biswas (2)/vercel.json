{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/send-email",
      "destination": "/api/send-email.ts"
    },
    {
      "source": "/api/contact",
      "destination": "/api/contact.ts"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
